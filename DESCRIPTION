Package: ratlas
Title: ATLAS Formatting Functions and Templates
Version: 0.1.1.9000
Authors@R: c(
    person("W. Jake", "Thompson", , "wjakethompson@gmail.com", role = c("aut", "cre"),
           comment = c(ORCID = "0000-0001-7339-0300")),
